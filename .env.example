# ── LLM (pick one — app runs in rule-based mode without any key) ──────────────
OPENAI_API_KEY=your_openai_api_key_here
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── AWS Bedrock (alternative LLM provider) ────────────────────────────────────
# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_REGION=us-east-1
# AWS_BEDROCK_MODEL=anthropic.claude-haiku-4-5-20251001-v1:0

# ── Database (SQLite used by default — set for PostgreSQL in production) ───────
# DATABASE_URL=postgresql://user:password@localhost:5432/homebuilder

# ── MCP Server (optional HTTP mode) ──────────────────────────────────────────
# MCP_SERVER_PORT=8000
