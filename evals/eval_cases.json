      {"id": "E003-C3", "description": "Policy steps returned (at least 3)",               "type": "agent_output_field", "agent": "Associate Productivity Agent", "field": "policy_steps", "min_length": 3},
      {"id": "E003-C4", "description": "Risk level is low (informational only)",           "type": "state_equals",   "key": "risk_level", "expected": "low"},
      {"id": "E003-C5", "description": "No approval required for guidance",                "type": "state_equals",   "key": "approval_required", "expected": false}
